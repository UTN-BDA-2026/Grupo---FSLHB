# Archivo de ejemplo para variables de entorno
# Copia este archivo como .env y completa los valores necesarios

# Base de datos (local/venv): MariaDB expuesta por Docker en localhost:3307
PROD_DATABASE_URI=mysql+pymysql://hockeyuser:hockeypass@localhost:3307/hockey
DATABASE_URL=mysql+pymysql://hockeyuser:hockeypass@localhost:3307/hockey

# Forzar HTTPS (modo recomendado con Traefik)
FORCE_HTTPS=true
# Cookies solo por HTTPS
SESSION_COOKIE_SECURE=true

# Cloudinary (formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME)
CLOUDINARY_URL=
