# Archivo de ejemplo para variables de entorno
# Copia este archivo como .env y completa los valores necesarios

# CRÍTICO en producción: generar una clave larga y aleatoria, no dejar vacía.
# Podés generarla con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Cómo se comporta la cookie de sesión frente a peticiones cross-site.
# Lax es el valor recomendado por defecto (protege contra CSRF sin romper navegación normal).
SESSION_COOKIE_SAMESITE=Lax

# Activa/desactiva la protección CSRF de Flask-WTF en toda la app.
ENABLE_CSRF=true

# Conexión a MongoDB donde se guarda la colección "usuarios".
MONGO_URI=mongodb://localhost:27017/hockey

# Base de datos (local/venv): MariaDB expuesta por Docker en localhost:3307
PROD_DATABASE_URI=mysql+pymysql://hockeyuser:hockeypass@localhost:3307/hockey
DATABASE_URL=mysql+pymysql://hockeyuser:hockeypass@localhost:3307/hockey

# Forzar HTTPS (modo recomendado con Traefik)
FORCE_HTTPS=true
# Cookies solo por HTTPS
SESSION_COOKIE_SECURE=true

# Cloudinary (formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME)
CLOUDINARY_URL=
